}

participant "IoT Device\n(Compromised)" as dev
participant "Open vSwitch (br0)"        as ovs
participant "Ryu Controller"            as ryu  #D5E8D4
participant "Zeek"                      as zeek #E1D5E7
participant "ML Pipeline"               as ml   #E1D5E7

note over dev
  The device has been compromised
  and is generating anomalous traffic
  (e.g. a port scan, connection to a
  known-bad IP, or data exfiltration
  exceeding volume thresholds).
end note

loop Anomalous traffic bursts

    dev  -> ovs  : Traffic (various destinations/ports)
    ovs --> zeek : [Mirror copy of all traffic on br0]
    ovs  -> ryu  : [Packet-In for unmatched flows]
    ryu  -> ovs  : Forward or drop per policy

end

note over zeek
  Zeek analyses the mirrored traffic
  stream in real time. Detection scripts
  run continuously against conn.log,
  dns.log, and other streams.
end note

group Zeek Rule-Based Detection

    zeek -> zeek : detect-port-scan.zeek:\nSumStats observes DEVICE_IP\ncontacting N unique dst ports\nwithin time window T.\nThreshold exceeded → CRITICAL

    zeek -> zeek : Write structured alert\nto iot_alerts.log:\n{ severity: CRITICAL,\n  src_ip: DEVICE_IP,\n  src_mac: DEVICE_MAC,\n  detector: "port_scan",\n  timestamp: NOW }

    alt auto_isolate = T (enabled in local.zeek)

        zeek -> ryu : POST /policy/isolate\n{ "mac": "DEVICE_MAC" }

        ryu -> ryu : Install OFPFlowMod:\npriority 65535,\nmatch eth_src=DEVICE_MAC,\nactions=DROP\n(overrides all other rules)

        ryu -> zeek : 200 OK\n{ "status": "isolated",\n  "mac": "DEVICE_MAC" }

        note over ovs
          All subsequent frames from
          DEVICE_MAC are dropped at
          priority 65535 before any
          other rule is evaluated.
          Isolation takes effect within
          one RTT of the API call.
        end note

    else auto_isolate = F (default)

        note over zeek
          Alert is logged. No automated
          action taken. Operator can
          manually POST to /policy/isolate
          to quarantine the device.
        end note

    end

end

group ML Pipeline Parallel Detection

    ml -> ml  : Isolation Forest scores\nfeature windows from\nconn.log for DEVICE_MAC.\nAnomaly score exceeds\nconfigured threshold.

    ml -> ml  : Write alert to ml_alerts.log:\n{ severity: CRITICAL,\n  src_mac: DEVICE_MAC,\n  model: "per_device",\n  score: ANOMALY_SCORE }

    ml -> ryu : POST /policy/isolate\n{ "mac": "DEVICE_MAC" }

    note over ryu
      If Zeek has already isolated
      the device, Ryu returns 200 OK
      but does not install a duplicate
      rule. The existing priority-65535
      rule remains in place.
    end note

    ryu -> ml : 200 OK

end

note over dev
  Device is isolated. No traffic
  from DEVICE_MAC leaves OVS.
  The device still holds its DHCP
  lease and WiFi association but
  cannot communicate on the network.
end note

@enduml
                                                                       

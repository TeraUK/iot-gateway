collections "Internet"           as inet  #F5F5F5

dev -> ovs : TCP SYN\nsrc:DEVICE_IP dst:UNPERMITTED_IP

note over ovs
  Priority-100 per-device intercept
  rule matches. Packet sent to
  controller (packet-in).
end note

ovs --> zeek : [Mirror copy] TCP SYN

ovs -> ryu : OpenFlow Packet-In

ryu -> ryu : Check DEVICE_MAC\nagainst device_profiles.json.\nDestination IP is NOT in\nallowed_cidrs or allowed_domains\n→ DENY

note over ryu
  Ryu does NOT install a forward
  rule. The packet is not re-injected
  into the data plane. It is silently
  dropped by the controller.
  The default-deny rule at priority 1
  handles any retransmissions that
  arrive before the controller responds.
end note

ryu -> ryu : Append entry to\ndenied-log:\n{ timestamp, device_mac,\n  device_ip, dest_ip,\n  dest_port, proto }

note over dev
  Device receives no response.
  The connection attempt times out.
  No flow rule is installed for
  this device/destination pair.
end note

note over inet
  The destination is never
  contacted.
end note

dev ->x ovs : TCP SYN (retransmit)

note over ovs
  Retransmitted packets hit the
  default-deny rule (priority 1)
  and are dropped in the data plane
  without involving the controller.
end note

@enduml
                                                                     

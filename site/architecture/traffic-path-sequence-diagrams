participant "IoT Device"         as dev
participant "Open vSwitch (br0)" as ovs
participant "Ryu Controller"     as ryu   #D5E8D4
participant "Zeek"               as zeek  #E1D5E7
participant "nftables"           as nft   #D5E8D4
participant "Internet"           as inet  #F5F5F5

dev -> ovs : TCP SYN\nsrc:DEVICE_IP dst:PERMITTED_IP

note over ovs
  Priority-100 per-device intercept
  rule matches. Packet sent to
  controller (packet-in). The general
  WAN rule at priority 50 is not
  reached for profiled devices.
end note

ovs --> zeek : [Mirror copy] TCP SYN

ovs -> ryu : OpenFlow Packet-In\n(first packet from this device\nto this destination)

note over ryu
  Ryu evaluates the destination IP
  against the device's allowlist profile
  loaded from device_profiles.json.
  DNS cache supplies IPs resolved
  from domain-based allowlist entries.
end note

ryu -> ryu : Check DEVICE_MAC\nagainst device_profiles.json\nDestination IP is in allowed_cidrs\nor matches an allowed_domain → PERMIT

ryu -> ovs : OFPFlowMod — install priority-500\nforward rule for this\nDEVICE_MAC + DEST_IP pair\n(with idle timeout)

note over ovs
  Subsequent packets in this flow
  match the priority-500 rule directly
  and are forwarded without involving
  the controller again.
end note

ovs -> nft : TCP SYN forwarded\nvia OFPP_LOCAL\n(host IP stack)

note over nft
  postrouting masquerade rule:
  src 192.168.50.0/24 out via enp2s0
  → rewrite src to WAN IP.
end note

nft -> inet : TCP SYN\n(masqueraded src: WAN_IP)
inet -> nft : TCP SYN-ACK
nft -> ovs  : TCP SYN-ACK\n(de-masqueraded)
ovs -> dev  : TCP SYN-ACK

note over dev, inet
  Connection established.
  Subsequent packets match the
  installed priority-500 flow rule
  and are forwarded without further
  controller involvement.
end note

loop Established session traffic

    dev  -> ovs  : Data packet
    ovs --> zeek : [Mirror copy]
    ovs  -> nft  : Forward via OFPP_LOCAL
    nft  -> inet : Outbound data\n(masqueraded)
    inet -> nft  : Inbound response
    nft  -> ovs  : Response
    ovs  -> dev  : Response

end

@enduml
                                                                   
